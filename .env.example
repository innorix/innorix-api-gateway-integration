# INNORIX Platform
INNORIX_BASE_URL=https://your-innorix-server.com
INNORIX_API_KEY=your_api_key

# Source
SOURCE_DEVICE_ID=source_device_id

# Single Target Transfer
TARGET_DEVICE_ID=target_device_id
TARGET_PATH=/data/transfer

# Transfer File
FILE_PATH=/packages/application.tar.gz
FILE_SIZE=21474836480

# Multi Distribution - Kubernetes
TARGET_CLUSTER_A=cluster_a_device_id
TARGET_CLUSTER_B=cluster_b_device_id
TARGET_CLUSTER_C=cluster_c_device_id

# Multi Distribution - Multi Region
TARGET_REGION_US=us_region_device_id
TARGET_REGION_EU=eu_region_device_id
TARGET_REGION_APAC=apac_region_device_id

# Common Target Path
TARGET_CLUSTER_PATH=/data/distribution

# Transfer Monitoring
AUTOMATION_ID=your_automation_id